# Backend Environment Variables Template
# Copy this file to .env and fill in your actual values

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Flask Configuration
FLASK_ENV=development
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Challenge Hashes (SHA256 of correct answers)
CHALLENGE_HASHES=odysseus:hash1,penelope:hash2,telemachus:hash3,athena:hash4,poseidon:hash5,circe:hash6,sirens:hash7,calypso:hash8,hermes:hash9,hephaestus:hash10,apollo:hash11,artemis:hash12,ares:hash13,hades:hash14,zeus:hash15

# Challenge Codes (revealed after solving)
CHALLENGE_CODES=odysseus:176,penelope:47,telemachus:20,athena:88,poseidon:33,circe:1441,sirens:6174,calypso:144,hermes:42,hephaestus:777,apollo:helios,artemis:ehfdcagb,ares:club,hades:504,zeus:olympus
